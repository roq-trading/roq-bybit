{
  "name": "REST",
  "type": "flags",
  "prefix": "rest_",
  "values": [
    {
      "name": "uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "https://api-testnet.bybit.com",
      "description": "REST end-point (URI)"
    },
    {
      "name": "host",
      "type": "std::string",
      "description": "Host (http header) in case uri uses an IP address"
    },
    {
      "name": "proxy",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "description": "Proxy end-point (URI)"
    },
    {
      "name": "ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "ping_path",
      "type": "std::string",
      "validator": "roq::flags::validators::Path",
      "default": "/v5/market/time",
      "description": "URI path used for REST connection keep-alive messages"
    },
    {
      "name": "request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "30s",
      "description": "Request: timeout"
    },
    {
      "name": "recv_window",
      "type": "std::chrono::milliseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "Recv window"
    },
    {
      "name": "terminate_on_403",
      "type": "bool",
      "default": false,
      "description": "Terminate on 403?"
    },
    {
      "name": "back_off_delay",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "30s",
      "description": "Back-off period"
    }
  ]
}
