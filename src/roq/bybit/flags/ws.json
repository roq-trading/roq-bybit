{
  "name": "WS",
  "type": "flags",
  "prefix": "ws_",
  "values": [
    {
      "name": "public_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://stream-testnet.bybit.com/v5/public",
      "description": "WS public end-point (URI)"
    },
    {
      "name": "public_host",
      "type": "std::string",
      "description": "Host (http header) in case uri uses an IP address"
    },
    {
      "name": "private_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://stream-testnet.bybit.com/v5/private",
      "description": "WS private end-point (URI)"
    },
    {
      "name": "private_host",
      "type": "std::string",
      "description": "Host (http header) in case uri uses an IP address"
    },
    {
      "name": "ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "15s",
      "description": "Request: timeout"
    },
    {
      "name": "max_subscriptions_per_stream",
      "type": "uint32_t",
      "required": true,
      "default": 100,
      "description": "Max symbols per connection (count)"
    },
    {
      "name": "mbp_depth",
      "type": "uint32_t",
      "default": 0,
      "description": "MbP depth"
    }
  ]
}
